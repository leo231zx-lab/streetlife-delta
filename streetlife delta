            local value = math.clamp(tonumber(v) or default, min, max) 
            Nytro.Flags[flag] = value 
            valBox.Text = tostring(value)
            if instant then
                sliderFill.Size = UDim2.new((value-min)/(max-min), 0, 1, 0)

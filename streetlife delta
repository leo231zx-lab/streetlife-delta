    local function enableInstantPrompts(enable)
        if enable then
            task.spawn(function()
                local count = 0
                for _, p in ipairs(workspace:GetDescendants()) do
                    if not Nytro.Flags["slr_prompt"] then break end
                    if p:IsA("ProximityPrompt") then
                        p.HoldDuration = 0
                    end
                    count = count + 1
                    if count % 200 == 0 then task.wait() end
                end
            end)
            if not promptConnection then
                promptConnection = PPS.PromptShown:Connect(function(prompt)
                    if Nytro.Flags["slr_prompt"] then
                        prompt.HoldDuration = 0
                    end
                end)
            end
        else
            if promptConnection then
                promptConnection:Disconnect()
                promptConnection = nil
            end
        end
    end


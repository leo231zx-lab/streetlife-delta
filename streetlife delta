                local cTrcM = Color3.fromRGB(flags["tr_r"] or 180, flags["tr_g"] or 80, flags["tr_b"] or 255)
                local cBoxM = Color3.fromRGB(flags["bx_r"] or 255, flags["bx_g"] or 255, flags["bx_b"] or 255)
                local cTxtM = Color3.fromRGB(flags["tx_r"] or 255, flags["tx_g"] or 255, flags["tx_b"] or 255)
                local cSkeM = Color3.fromRGB(flags["sk_r"] or 255, flags["sk_g"] or 255, flags["sk_b"] or 255)
                local cTarM = Color3.fromRGB(flags["ta_r"] or 255, flags["ta_g"] or 40, flags["ta_b"] or 40)
                local cAlM  = Color3.fromRGB(flags["al_r"] or 0, flags["al_g"] or 255, flags["al_b"] or 150)
                local cHdM  = Color3.fromRGB(flags["hd_r"] or 255, flags["hd_g"] or 0, flags["hd_b"] or 80)
                local rbwC  = flags["rbwesp"] and Color3.fromHSV(tick() % 5 / 5, 1, 1) or nil
                
                for i = 1, #players do
                    local p = players[i]
                    if p ~= LP then
                        local esp = GetESP(p)
                        local showPlayer = true

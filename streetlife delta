        pcall(function()
            print("[NyTro.cc] Unlink iniciado... cerrando todo.")
            
            -- 1. Desactivar TODOS los flags booleanos (apaga todos los toggles/módulos)
            for k, v in pairs(Nytro.Flags) do
                if type(v) == "boolean" then
                    Nytro.Flags[k] = false
                end
            end
            
            -- 2. Matar TODOS los Tasks del loop engine (Heartbeat, RenderStepped, Stepped)
            pcall(function()
                for taskType, tasks in pairs(Nytro.Tasks) do
                    for taskId, _ in pairs(tasks) do
                        tasks[taskId] = nil
                    end
                end
                Nytro.Tasks = { Heartbeat = {}, RenderStepped = {}, Stepped = {} }
                Nytro.Diagnostics.ThreadCount = 0
            end)
            
            -- 3. Desconectar TODAS las conexiones registradas (eventos de Input, PlayerRemoving, etc.)
            for connName, conn in pairs(Nytro.Connections) do
                pcall(function() 
                    if typeof(conn) == "RBXScriptConnection" then
                        conn:Disconnect()
                    end
                end)
            end
            Nytro.Connections = {}
            
            -- 4. Desligar el framework del RenderStep
            pcall(function() RS:UnbindFromRenderStep("Nytro_Framework") end)
            
            -- 5. Limpiar dibujos en pantalla (Crosshair, FOV Ring, ESPs)
            pcall(function() if CrosshairL then CrosshairL:Remove() end end)
            pcall(function() if CrosshairR then CrosshairR:Remove() end end)
            pcall(function() if CrosshairT then CrosshairT:Remove() end end)
            pcall(function() if CrosshairB then CrosshairB:Remove() end end)
            pcall(function() if CrosshairD then CrosshairD:Remove() end end)
            pcall(function() if FOVCirc then FOVCirc:Remove() end end)
            pcall(function() if FOVFill then FOVFill:Remove() end end)
            
            -- 6. Limpiar cache completo de ESP (dibujos 2D + esqueletos)
            pcall(function()
                for _, esp in pairs(ESPCache) do
                    for k, obj in pairs(esp) do
                        if k == "Ske" then
                            for _, line in pairs(obj) do
                                pcall(function() line:Remove() end)
                            end
                        else
                            pcall(function() obj:Remove() end)
                        end
                    end
                end
                ESPCache = {}
            end)
            
            -- 7. Eliminar Chams 3D y Highlights de todos los jugadores
            pcall(function()
                for _, p in pairs(PLRS:GetPlayers()) do
                    if p.Character then
                        pcall(function() if p.Character:FindFirstChild("Nytro_Chams") then p.Character.Nytro_Chams:Destroy() end end)
                        pcall(function() if p.Character:FindFirstChildOfClass("Highlight") then p.Character:FindFirstChildOfClass("Highlight"):Destroy() end end)
                    end
                end
            end)
            
            -- 8. Restablecer personaje a valores normales
            pcall(function() WS.Gravity = 196.2 end)
            pcall(function() 
                if LP.Character and LP.Character:FindFirstChild("Humanoid") then
                    LP.Character.Humanoid.WalkSpeed = 16
                    LP.Character.Humanoid.JumpPower = 50
                end
            end)
            
            -- 9. Quitar el efecto Blur de glassmorphism
            pcall(function() if Blur then Blur:Destroy() end end)
            
            -- 10. Animación de cierre y destruir la UI
            pcall(function()
                local closeAnim = TS:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                    Size = UDim2.new(0, 0, 0, 0),
                    BackgroundTransparency = 1
                })
                closeAnim:Play()
                closeAnim.Completed:Connect(function()
                    pcall(function() if SG then SG:Destroy() end end)
                end)
            end)
            
            print("[NyTro.cc] Unlink completado. Todo apagado y limpio.")
        end) 
    end)


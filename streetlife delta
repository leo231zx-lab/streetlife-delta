                -- Anti-Cheat Bypass
                if not checkcaller() then
                    if method == "Kick" then
                        Nytro.Log("Blocked Kick attempt from client", "Error")
                        return
                    end
                    if method == "FireServer" then
                        local name = tostring(self)
                        if name == "Ban" or name == "Report" or name == "Log" or name == "Admins" then
                            Nytro.Log("Blocked AntiCheat remote: " .. name, "Error")
                            return
                        end
                    end
                end
                
                -- Silent Aim / Magic Bullets
                local aimPart = nil
                if Nytro.Flags["magic"] then
                    local fovR = Nytro.Flags["fovRadius"] or 150
                    local bestDist = fovR
                    local center = UIS:GetMouseLocation()
                    for _, p in ipairs(PLRS:GetPlayers()) do
                        if p ~= LP and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 and p.Character:FindFirstChild("Head") then
                            local pos, vis = CAM:WorldToViewportPoint(p.Character.Head.Position)
                            if vis then
                                local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                                if d < bestDist then
                                    bestDist = d
                                    aimPart = p.Character.Head
                                end
                            end
                        end
                    end
                elseif Nytro.Flags["silent"] and Nytro.Target then
                    aimPart = getAimPart(Nytro.Target)
                end

                if not checkcaller() then
                    if aimPart then
                        -- Intercept Screen Rays
                        if method == "ViewportPointToRay" or method == "ScreenPointToRay" then
                            return Ray.new(CAM.CFrame.Position, (aimPart.Position - CAM.CFrame.Position).Unit)
                        end

                        -- Intercept Raycasts
                        if method == "FindPartOnRayWithIgnoreList" or method == "Raycast" or method == "FindPartOnRay" or method == "FindPartOnRayWithWhitelist" then
                            local origin = args[1]
                            if typeof(origin) ~= "Vector3" then origin = CAM.CFrame.Position end
                            
                            local targetPos = aimPart.Position
                            pcall(function()
                                if Nytro.Flags["pred"] and aimPart.Parent:FindFirstChild("HumanoidRootPart") then
                                    targetPos = targetPos + (aimPart.Parent.HumanoidRootPart.Velocity * 0.05)
                                end
                            end)
                            local dir = (targetPos - origin).Unit * 5000
                            
                            if method == "Raycast" then 
                                args[2] = dir 
                                if Nytro.Flags["wallb"] and args[3] then
                                    local newParams = RaycastParams.new()
                                    newParams.FilterType = Enum.RaycastFilterType.Exclude
                                    newParams.FilterDescendantsInstances = {workspace:FindFirstChild("Map") or workspace}
                                    newParams.IgnoreWater = true
                                    args[3] = newParams
                                end
                            else 
                                args[1] = Ray.new(origin, dir) 
                                if Nytro.Flags["wallb"] then
                                    args[2] = {workspace:FindFirstChild("Map") or workspace}
                                end
                            end
                            return oldNamecall(self, unpack(args))
                        end
                    end
                    
                    -- Intercept Network Calls for Gun Mods
                    if method == "FireServer" or method == "InvokeServer" then
                        local remoteName = string.lower(tostring(self))
                        local isWeaponRemote = string.find(remoteName, "shoot") or string.find(remoteName, "hit") or string.find(remoteName, "bullet") or string.find(remoteName, "gun") or string.find(remoteName, "damage") or string.find(remoteName, "event") or string.find(remoteName, "fire") or string.find(remoteName, "dmg") or string.find(remoteName, "attack") or string.find(remoteName, "combat")
                        
                        if (isWeaponRemote or remoteName == "remoteevent" or remoteName == "remotefunction" or remoteName == "mainevent") and (Nytro.Flags["norec"] or Nytro.Flags["nospr"] or aimPart) then
                            local modified = false
                            
                            local function modifyDeep(t)
                                for i, arg in pairs(t) do
                                    if type(arg) == "table" then
                                        pcall(function() modifyDeep(arg) end)
                                    elseif typeof(arg) == "Vector3" then
                                        if aimPart and typeof(t[i]) == "Vector3" then 
                                            t[i] = aimPart.Position modified = true
                                        elseif Nytro.Flags["norec"] and typeof(t[i]) == "Vector3" then 
                                            t[i] = Vector3.new(arg.X, 0, arg.Z) modified = true 
                                        end
                                    elseif typeof(arg) == "CFrame" then
                                        if aimPart and typeof(t[i]) == "CFrame" then 
                                            t[i] = aimPart.CFrame modified = true
                                        elseif Nytro.Flags["nospr"] and typeof(t[i]) == "CFrame" then 
                                            t[i] = CAM.CFrame modified = true 
                                        end
                                    elseif typeof(arg) == "Instance" and arg:IsA("BasePart") then
                                        if aimPart then t[i] = aimPart modified = true end
                                    elseif type(arg) == "number" then
                                        if math.abs(arg) < 1 and arg ~= 0 then
                                            if Nytro.Flags["nospr"] then t[i] = 0 modified = true end
                                        elseif (arg > 0 and arg <= 5) and (Nytro.Flags["norec"] or Nytro.Flags["nospr"]) then
                                            t[i] = 0 modified = true
                                        end
                                    end
                                end
                            end
                            
                            pcall(function() modifyDeep(args) end)
                            
                            if modified then
                                return oldNamecall(self, unpack(args))
                            end
                        end
                    end
                end
                
                return oldNamecall(self, ...)
            end))
        end
    end)


                if typeof(key) == "EnumItem" then
                    if key.EnumType == Enum.UserInputType then isAiming = UIS:IsMouseButtonPressed(key)
                    elseif key.EnumType == Enum.KeyCode then isAiming = UIS:IsKeyDown(key) end
                end
                
                if isAiming then
                    local aimPart = getAimPart(tChar)
                    if aimPart then
                        if flags["strafe"] and lpHrp then
                            pcall(function()
                                local radius = flags["strafeD"] or 15
                                if (lpHrp.Position - aimPart.Position).Magnitude <= (radius + 40) then
                                    local t = tick() * (flags["strafeS"] or 3)
                                    lpHrp.CFrame = aimPart.CFrame * CFrame.new(math.cos(t) * radius, 0, math.sin(t) * radius)
                                    lpHrp.CFrame = CFrame.lookAt(lpHrp.Position, aimPart.Position)
                                end
                            end)
                        end
                        local targetPos = aimPart.Position
                        if flags["pred"] and tChar:FindFirstChild("HumanoidRootPart") then
                            local vel = tChar.HumanoidRootPart.Velocity
                            if flags["reso"] and vel.Magnitude > 130 then vel = v3(0, 0, 0) end
                            Nytro.SmoothVel = (Nytro.SmoothVel or v3()):Lerp(vel, 0.3)
                            targetPos = targetPos + (Nytro.SmoothVel / 6)
                        end
                        
                        local smooth = flags["aimSmooth"] or 2
                        local speed = clamp(1 - (smooth / 12), 0.15, 0.95)
                        CAM.CFrame = CAM.CFrame:Lerp(CFrame.lookAt(camPos, targetPos), speed)
                    end
                end
            end
            
            if flags["trg"] or flags["autos"] then
                if not triggerDebounce then
                    local mt = LP:GetMouse().Target
                    if (mt and mt.Parent and mt.Parent:FindFirstChild("Humanoid") and mt.Parent.Name ~= LP.Name) or (flags["autos"] and tChar) then
                        triggerDebounce = true pcall(function() mouse1click() end) task.wait(0.05) triggerDebounce = false
                    end
                end
            end
            
            if flags["autor"] then
                pcall(function() if game.ReplicatedStorage:FindFirstChild("MainEvent") then game.ReplicatedStorage.MainEvent:FireServer("Reload") end end)
            end
            
            local espOn = flags["esp_on"]

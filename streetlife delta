                                        local boxOutline = e_out and GetDrawing(esp, "BoxOutline", "Square", {Filled = false, Thickness = f_thk + 2, Color = Color3.new(0,0,0)})
                                        local boxFill = e_fil and GetDrawing(esp, "BoxFill", "Square", {Filled = true, Transparency = 0.2, Color = cBox})
                                        local bSz = v2(width, height)
                                        local bPs = v2(pos.X - width/2, pos.Y - height/2)
                                        if box then box.Size = bSz box.Position = bPs box.Color = cBox box.Thickness = f_thk box.Visible = true end
                                        if boxOutline then boxOutline.Size = bSz boxOutline.Position = bPs boxOutline.Color = Color3.new(0,0,0) boxOutline.Thickness = f_thk + 2 boxOutline.Visible = true else if esp.BoxOutline then esp.BoxOutline.Visible = false end end
                                        if boxFill then boxFill.Size = bSz boxFill.Position = bPs boxFill.Color = cBox boxFill.Visible = true else if esp.BoxFill then esp.BoxFill.Visible = false end end
                                    else
                                        if esp.Box then esp.Box.Visible = false end
                                        if esp.BoxOutline then esp.BoxOutline.Visible = false end
                                        if esp.BoxFill then esp.BoxFill.Visible = false end
                                    end
                                    
                                    if e_nms or e_dnm then
                                        local text = GetDrawing(esp, "Text", "Text", {Center = true, Outline = e_out, Color = cTxt, Size = f_txt, Font = f_font})
                                        if text then text.Text = e_dnm and p.DisplayName or p.Name text.Position = v2(pos.X, pos.Y - height/2 - f_txt - 5) text.Size = f_txt text.Color = cTxt text.Font = f_font text.Outline = e_out text.Visible = true end
                                    else
                                        if esp.Text then esp.Text.Visible = false end
                                    end
                                    
                                    local distY = 5
                                    if e_dis then
                                        local distText = GetDrawing(esp, "DistText", "Text", {Center = true, Outline = e_out, Color = cTxt, Size = clamp(f_txt - 2, 10, 20), Font = f_font})
                                        if distText then
                                            distText.Text = "[" .. floor(dist) .. "m]"
                                            distText.Position = v2(pos.X, pos.Y + height/2 + distY)
                                            distText.Size = clamp(f_txt - 2, 10, 20)
                                            distText.Color = cTxt
                                            distText.Font = f_font
                                            distText.Outline = e_out
                                            distText.Visible = true
                                        end
                                        distY = distY + f_txt
                                    else
                                        if esp.DistText then esp.DistText.Visible = false end
                                    end
                                    
                                    if e_wpn then
                                        local wpnText = GetDrawing(esp, "WpnText", "Text", {Center = true, Outline = e_out, Color = cTxt, Size = clamp(f_txt - 2, 10, 20), Font = f_font})
                                        if wpnText then
                                            local tool = char:FindFirstChildOfClass("Tool")
                                            wpnText.Text = tool and tool.Name or "None"
                                            wpnText.Position = v2(pos.X, pos.Y + height/2 + distY)
                                            wpnText.Size = clamp(f_txt - 2, 10, 20)
                                            wpnText.Color = cTxt
                                            wpnText.Font = f_font
                                            wpnText.Outline = e_out
                                            wpnText.Visible = true
                                        end
                                    else
                                        if esp.WpnText then esp.WpnText.Visible = false end
                                    end
                                    
                                    if e_trc then
                                        local tracer = GetDrawing(esp, "Tracer", "Line", {Thickness = f_thk, Color = cTrc})
                                        if tracer then
                                            local origin = v2(viewport.X/2, viewport.Y)
                                            if flags["trcpos"] == "Mouse" then origin = mousePos elseif flags["trcpos"] == "Centro" or flags["trcpos"] == "Center" then origin = center end
                                            tracer.From = origin tracer.To = v2(pos.X, pos.Y + height/2) tracer.Color = cTrc tracer.Thickness = f_thk tracer.Visible = true
                                        end
                                    else
                                        if esp.Tracer then esp.Tracer.Visible = false end
                                    end
                                    
                                    local maxHp = hum.MaxHealth > 0 and hum.MaxHealth or 100
                                    local hpVal = hum.Health / maxHp
                                    local hpColor = Color3.fromHSV(hpVal * 0.3, 1, 1)
                                    
                                    if e_hpb then
                                        local healthBar = GetDrawing(esp, "HealthBar", "Line", {Thickness = f_thk + 1, Color = hpColor})
                                        local healthBarOut = GetDrawing(esp, "HealthBarOut", "Line", {Thickness = f_thk + 3, Color = Color3.new(0,0,0)})
                                        local hX = pos.X - width/2 - (f_thk*2) - 4
                                        local hY1 = pos.Y - height/2
                                        local hY2 = pos.Y + height/2
                                        if healthBarOut then healthBarOut.From = v2(hX, hY1) healthBarOut.To = v2(hX, hY2) healthBarOut.Thickness = f_thk + 3 healthBarOut.Visible = true end
                                        if healthBar then healthBar.From = v2(hX, hY2) healthBar.To = v2(hX, hY2 - (height * hpVal)) healthBar.Color = hpColor healthBar.Thickness = f_thk + 1 healthBar.Visible = true end
                                    else
                                        if esp.HealthBar then esp.HealthBar.Visible = false end
                                        if esp.HealthBarOut then esp.HealthBarOut.Visible = false end
                                    end
                                    
                                    if e_hptx then
                                        local hpText = GetDrawing(esp, "HpText", "Text", {Center = true, Outline = e_out, Color = hpColor, Size = 12, Font = f_font})
                                        if hpText then hpText.Text = floor(hpVal * 100) .. "%" hpText.Position = v2(pos.X - width/2 - (f_thk*2) - 25, pos.Y - height/2 + (height * (1-hpVal)) - 5) hpText.Color = hpColor hpText.Font = f_font hpText.Outline = e_out hpText.Visible = true end
                                    else
                                        if esp.HpText then esp.HpText.Visible = false end
                                    end
                                    
                                    if e_hdot then
                                        local hdPos, hdVis = wtvp(CAM, char:FindFirstChild("Head") and char.Head.Position or hrp.Position + v3(0, 1.5, 0))
                                        if hdVis then
                                            local headDot = GetDrawing(esp, "HeadDot", "Circle", {Filled = true, Radius = 3, Color = cHdM})
                                            if headDot then headDot.Position = v2(hdPos.X, hdPos.Y) headDot.Color = cHdM headDot.Visible = true end
                                        else
                                            if esp.HeadDot then esp.HeadDot.Visible = false end
                                        end
                                    else
                                        if esp.HeadDot then esp.HeadDot.Visible = false end
                                    end
                                    
                                    if e_aimln and isTar then
                                        local hdPos, hdVis = wtvp(CAM, char:FindFirstChild(aimPartStr) and char[aimPartStr].Position or hrp.Position)
                                        if hdVis then
                                            local aimLine = GetDrawing(esp, "AimLine", "Line", {Thickness = 1.5, Color = cAlM})
                                            if aimLine then aimLine.From = center aimLine.To = v2(hdPos.X, hdPos.Y) aimLine.Color = cAlM aimLine.Visible = true end
                                        else
                                            if esp.AimLine then esp.AimLine.Visible = false end
                                        end
                                    else
                                        if esp.AimLine then esp.AimLine.Visible = false end
                                    end
                                    
                                    if e_ske then
                                        if not esp.Ske then
                                            esp.Ske = {
                                                Spine = GetDrawing(esp, "Ske_Spine", "Line", {Thickness = f_thk, Color = cSke}),
                                                LArm = GetDrawing(esp, "Ske_LArm", "Line", {Thickness = f_thk, Color = cSke}),
                                                RArm = GetDrawing(esp, "Ske_RArm", "Line", {Thickness = f_thk, Color = cSke}),
                                                LLeg = GetDrawing(esp, "Ske_LLeg", "Line", {Thickness = f_thk, Color = cSke}),
                                                RLeg = GetDrawing(esp, "Ske_RLeg", "Line", {Thickness = f_thk, Color = cSke})
                                            }
                                        end
                                        
                                        if esp.Char ~= char then
                                            esp.Char = char
                                            esp.Hd = char:FindFirstChild("Head")
                                            esp.Ts = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
                                            esp.La = char:FindFirstChild("Left Arm") or char:FindFirstChild("LeftUpperArm")
                                            esp.Ra = char:FindFirstChild("Right Arm") or char:FindFirstChild("RightUpperArm")
                                            esp.Ll = char:FindFirstChild("Left Leg") or char:FindFirstChild("LeftUpperLeg")
                                            esp.Rl = char:FindFirstChild("Right Leg") or char:FindFirstChild("RightUpperLeg")
                                        end
                                        
                                        local function cL(l, p1, p2) 
                                            if not l then return end
                                            if not p1 or not p2 then l.Visible = false return end 
                                            local pA, oA = wtvp(CAM, p1.Position) 
                                            local pB, oB = wtvp(CAM, p2.Position) 
                                            if oA and oB then l.From = v2(pA.X, pA.Y) l.To = v2(pB.X, pB.Y) l.Visible = true else l.Visible = false end 
                                        end
                                        cL(esp.Ske.Spine, esp.Hd, esp.Ts) cL(esp.Ske.LArm, esp.Ts, esp.La) cL(esp.Ske.RArm, esp.Ts, esp.Ra) cL(esp.Ske.LLeg, esp.Ts, esp.Ll) cL(esp.Ske.RLeg, esp.Ts, esp.Rl)
                                    else
                                        if esp.Ske then
                                            for _, l in pairs(esp.Ske) do if l then l.Visible = false end end
                                        end
                                    end
                                else
                                    hideESP(esp)
                                end
                            end
                        else
                            hideESP(esp)
                        end
                    end
                end
            else
                for i = 1, #players do hideESP(GetESP(players[i])) end
            end
        end)
    end)


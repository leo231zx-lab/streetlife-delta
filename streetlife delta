        UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
        RS.RenderStepped:Connect(function()
            if dragging then pcall(function() local r = math.clamp((UIS:GetMouseLocation().X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1) updateVal(math.floor(min + (max - min) * r), true) end) end

    AddToggle(sFarm, "P_ASHINE", "ashine", function(v) 
        if v then 
            task.spawn(function()
                while Nytro.Flags["ashine"] do
                    pcall(function() 
                        local char = LP.Character
                        local hrp = char and char:FindFirstChild("HumanoidRootPart")
                        local hum = char and char:FindFirstChildOfClass("Humanoid")
                        if not hrp or not hum or hum.Health <= 0 then return end
                        
                        local map = WS:FindFirstChild("Map")
                        if not map then return end
                        
                        -- Check if we already have a job active
                        local hasJob = false
                        pcall(function()
                            hasJob = LP:FindFirstChild("Data") and LP.Data:FindFirstChild("Job") and LP.Data.Job.Value ~= ""
                        end)
                        
                        local targetPrompt, targetPart = nil, nil
                        
                        if not hasJob then
                            -- No job: walk to an NPC to accept one
                            local jobs = map:FindFirstChild("Jobs")
                            if jobs then
                                local jobNPCs = {"CleanNPC", "DeliveryJob", "BoxJob", "FrostyJob"}
                                for _, npcName in ipairs(jobNPCs) do
                                    local npc = jobs:FindFirstChild(npcName)
                                    if npc then
                                        for _, desc in pairs(npc:GetDescendants()) do
                                            if desc:IsA("ProximityPrompt") and desc.Enabled then
                                                targetPrompt = desc
                                                targetPart = desc.Parent
                                                if targetPart and not targetPart:IsA("BasePart") then
                                                    targetPart = npc:FindFirstChildOfClass("BasePart")
                                                end
                                                break
                                            end
                                        end
                                        if not targetPrompt then
                                            for _, desc in pairs(npc:GetDescendants()) do
                                                if desc.Name == "Handler" and desc:IsA("ProximityPrompt") then
                                                    targetPrompt = desc
                                                    targetPart = desc.Parent
                                                    if targetPart and not targetPart:IsA("BasePart") then
                                                        targetPart = npc:FindFirstChildOfClass("BasePart")
                                                    end
                                                    break
                                                end
                                            end
                                        end
                                        if targetPrompt and targetPart then break end
                                        targetPrompt, targetPart = nil, nil
                                    end
                                end
                            end
                        else
                            -- Already have a job: find the closest task prompt to walk to
                            local taskKeywords = {"clean", "grab", "deliver", "end delivery", "drop off", "pick up", "sweep", "mop", "box", "frosty", "serve", "spill", "wash", "wipe", "scrub", "puddle", "water"}
                            local bestDist = math.huge
                            
                            -- Buscar en workspace en lugar de solo map por si algunos charcos spawnean fuera
                            local searchRoot = workspace:FindFirstChild("Map") or workspace
                            for _, desc in pairs(searchRoot:GetDescendants()) do
                                if desc:IsA("ProximityPrompt") and desc.Enabled then
                                    local matches = false
                                    local aText = desc.ActionText and string.lower(desc.ActionText) or ""
                                    local oText = desc.ObjectText and string.lower(desc.ObjectText) or ""
                                    local nText = desc.Name and string.lower(desc.Name) or ""
                                    
                                    for _, kw in ipairs(taskKeywords) do
                                        if aText:find(kw) or oText:find(kw) or nText:find(kw) then
                                            matches = true
                                            break
                                        end
                                    end
                                    
                                    if matches then
                                        local part = desc.Parent
                                        if part and not part:IsA("BasePart") then
                                            part = part:FindFirstChildOfClass("BasePart") or (part.Parent and part.Parent:FindFirstChildOfClass("BasePart"))
                                        end
                                        
                                        if part and part:IsA("BasePart") then
                                            local dist = (part.Position - hrp.Position).Magnitude
                                            if dist < bestDist then
                                                bestDist = dist
                                                targetPrompt = desc
                                                targetPart = part
                                            end
                                        end
                                    end
                                end
                            end
                        end
                        
                        -- Walk to the target
                        if targetPrompt and targetPart and targetPart:IsA("BasePart") then
                            local goalPos = targetPart.Position
                            local dist = (goalPos - hrp.Position).Magnitude
                            
                            -- Pre-configure prompt so it fires instantly when in range
                            pcall(function()
                                targetPrompt.MaxActivationDistance = 999
                                targetPrompt.RequiresLineOfSight = false
                            end)
                            
                            if dist > 5 then
                                hum:MoveTo(goalPos)
                                
                                local startWalk = tick()
                                
                                while (tick() - startWalk) < 30 and Nytro.Flags["ashine"] do
                                    local currentDist = math.huge
                                    pcall(function()
                                        currentDist = (targetPart.Position - hrp.Position).Magnitude
                                    end)
                                    
                                    -- Fire prompt the INSTANT we're close enough
                                    if currentDist < 15 then
                                        pcall(function() Nytro.FirePrompt(targetPrompt) end)
                                        break
                                    end
                                    
                                    -- Re-issue MoveTo every 6 seconds
                                    if (tick() - startWalk) % 6 < 0.15 and (tick() - startWalk) > 1 then
                                        pcall(function() hum:MoveTo(targetPart.Position) end)
                                    end
                                    
                                    task.wait(0.1)
                                end
                            else
                                -- Already close, fire immediately
                                pcall(function() Nytro.FirePrompt(targetPrompt) end)
                            end
                        end
                    end) 
                    task.wait(0.5)
                end
            end)
        else 
            -- Stop walking
            pcall(function()
                if LP.Character and LP.Character:FindFirstChildOfClass("Humanoid") then
                    LP.Character:FindFirstChildOfClass("Humanoid"):MoveTo(LP.Character.HumanoidRootPart.Position)
                end
            end)
        end 
    end)


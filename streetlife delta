            local _place = game.PlaceId
            local _servers = Api..tostring(_place).."/servers/Public?sortOrder=Asc&limit=100"
            
            local function ListServers(cursor)
                local Raw = game:HttpGet(_servers .. ((cursor and "&cursor="..cursor) or ""))

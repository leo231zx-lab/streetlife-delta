                        local char = p.Character
                        local hum = char and char:FindFirstChild("Humanoid")
                        local hrp = char and char:FindFirstChild("HumanoidRootPart")
                        
                        if showPlayer and hum and hrp and hum.Health > 0 then
                            local maxD = flags["aim_maxd"] or 1000
                            local dist = lpHrp and (hrp.Position - lpHrp.Position).Magnitude or 0
                            if dist > maxD then
                                hideESP(esp)
                            else
                                local pos, onScreen = wtvp(CAM, hrp.Position)
                                if onScreen then
                                    local rootTop, _ = wtvp(CAM, hrp.Position + v3(0, 3, 0))
                                    local rootBot, _ = wtvp(CAM, hrp.Position - v3(0, 3.5, 0))
                                    local height = abs(rootTop.Y - rootBot.Y)
                                    local width = height * 0.65
                                    
                                    local isTar = (flags["esp_tar"] and tChar == char)
                                    local cBox = isTar and cTarM or (rbwC or cBoxM)
                                    local cTxt = isTar and cTarM or (rbwC or cTxtM)
                                    local cTrc = isTar and cTarM or (rbwC or cTrcM)
                                    local cSke = isTar and cTarM or (rbwC or cSkeM)
                                    
                                    if e_box then

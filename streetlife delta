                                            rayP.FilterDescendantsInstances = {CAM, lpChar, char} 
                                            rayP.FilterType = Enum.RaycastFilterType.Exclude
                                            isVis = (WS:Raycast(camPos, partPos - camPos, rayP) == nil)
                                        end
                                        if isVis then aimDist = d Nytro.Target = char end
                                    end
                                end
                            end

                            local rs = game:GetService("ReplicatedStorage")
                            if rs:FindFirstChild("DefaultChatSystemChatEvents") then rs.DefaultChatSystemChatEvents.SayMessageRequest:FireServer(msgs[math.random(1, #msgs)], "All") end
                        end)
                    end

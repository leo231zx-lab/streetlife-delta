                            table.insert(validServers, s.id)
                        end
                    end
                    cursor = Servers.nextPageCursor
                    if not cursor then break end
                else
                    break
                end
            end
            
            if #validServers > 0 then
                TPS:TeleportToPlaceInstance(_place, validServers[math.random(1, #validServers)], LP)
            end

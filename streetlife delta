                local e_nms, e_dnm = flags["nms"], flags["dnm"]
                local e_hpb, e_hptx = flags["hpb"], flags["hptx"]
                local e_wpn, e_dis, e_trc = flags["wpn"], flags["dis"], flags["trc"]
                local e_hdot, e_aimln, e_ske = flags["hdot"], flags["aimln"], flags["ske"]
                
                local f_thk = flags["esp_thk"] or 1

    -- Smooth Teleport: moves the player in small incremental steps to avoid anti-clip/teleport detection
    -- speed: studs per step (default 120), returns true when arrived
    Nytro._smoothTPState = nil
    function Nytro.SmoothTP(targetCFrame, speed)
        speed = speed or 120
        local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end
        
        local origin = hrp.Position
        local goal = targetCFrame.Position
        local dist = (goal - origin).Magnitude
        
        -- If already close enough, just snap
        if dist < 8 then
            hrp.CFrame = targetCFrame
            return true
        end
        
        -- Move in incremental steps each frame to simulate walking
        local steps = math.max(math.ceil(dist / speed), 2)
        local stepDelay = 0.03 -- ~30fps movement cadence
        
        Nytro._smoothTPState = {active = true, target = targetCFrame}
        
        for i = 1, steps do
            if not Nytro._smoothTPState or not Nytro._smoothTPState.active then return false end
            local hrpCheck = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if not hrpCheck then return false end
            
            local alpha = i / steps
            local pos = origin:Lerp(goal, alpha)
            hrpCheck.CFrame = CFrame.new(pos) * (targetCFrame - targetCFrame.Position)
            hrpCheck.Velocity = Vector3.new(0, 0, 0)
            pcall(function() hrpCheck.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end)
            task.wait(stepDelay)
        end
        
        -- Final snap to exact position
        pcall(function()
            local hrpFinal = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if hrpFinal then hrpFinal.CFrame = targetCFrame end
        end)
        Nytro._smoothTPState = nil
        return true
    end

    function Nytro.CancelSmoothTP()
        if Nytro._smoothTPState then Nytro._smoothTPState.active = false end
        Nytro._smoothTPState = nil
    end

    -- Find a ProximityPrompt recursively in a model/folder
    function Nytro.FindPrompt(parent, nameFilter, actionFilter)
        if not parent then return nil, nil end
        for _, obj in pairs(parent:GetDescendants()) do
            if obj:IsA("ProximityPrompt") and obj.Enabled then
                local nameOk = not nameFilter or obj.Name == nameFilter or (obj.ObjectText and obj.ObjectText:find(nameFilter))
                local actionOk = not actionFilter or (obj.ActionText and obj.ActionText:find(actionFilter))
                if nameOk or actionOk then
                    local part = obj.Parent
                    if part and part:IsA("BasePart") then
                        return obj, part
                    end
                end
            end
        end
        return nil, nil
    end

    -- Safe interact: tp smoothly + fire prompt + return
    function Nytro.SafeInteract(promptObj, partObj, returnAfter)
        if not promptObj or not partObj then return false end
        local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end
        
        local originalCFrame = hrp.CFrame
        local targetCF = partObj.CFrame * CFrame.new(0, 0, -3)
        
        -- Smooth teleport to the prompt
        Nytro.SmoothTP(targetCF, 150)
        
        -- Wait a moment so server registers position
        task.wait(0.15)
        
        -- Fire the prompt
        promptObj.MaxActivationDistance = 999
        promptObj.RequiresLineOfSight = false
        Nytro.FirePrompt(promptObj)
        
        -- Optionally return to original position
        if returnAfter then
            task.wait(0.2)
            Nytro.SmoothTP(originalCFrame, 150)
        end
        
        return true
    end


    function Nytro.FireRemote(name, ...)
        local rs = game:GetService("ReplicatedStorage")
        local remotes = rs:FindFirstChild("Remotes") or rs:FindFirstChild("Events")
        
        local remote = nil
        if remotes then remote = remotes:FindFirstChild(name) end
        if not remote then remote = rs:FindFirstChild(name) end
        
        if remote then
            if remote:IsA("RemoteEvent") then
                remote:FireServer(...)
                return true
            elseif remote:IsA("RemoteFunction") then
                return remote:InvokeServer(...)
            end
        end
        
        -- FALLBACK: Comprar a distancia = Teleport instantáneo + comprar + volver
        if name == "BuyWeapon" or name == "BuyAmmo" or name == "BuyVest" then
            local weaponName = (...) or name
